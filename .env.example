# ===== JWT & Admin =====
JWT_SECRET_KEY=          # 生成方式: openssl rand -hex 32
ADMIN_SECRET_KEY=        # 管理员登录密钥，至少 32 位随机字符串
ENV=production           # production 或 development

# ===== 邮件发送（163 邮箱） =====
SENDER_EMAIL=            # 如 yourname@163.com
SENDER_AUTH_CODE=        # 163 邮箱 SMTP 授权码（非登录密码）

# ===== Frontend =====
FRONTEND_BASE_URL=https://littlebanbrick.cn   # 前端公网地址（用于邮件中的验证链接）

# ===== DeepSeek AI =====
DEEPSEEK_API_KEY=        # DeepSeek API Key，用于 GitHub Trending 摘要和 @deepseek 评论回复

# ===== MCP（可选） =====
MCP_SECRET_KEY=          # MCP Server 认证密钥，用于 AI 助手远程发帖
